# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database
# Leave unset to use SQLite (local dev only, not for production)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# AI — Anthropic Claude (primary, recommended)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AI — Google Gemini (fallback if Claude not configured)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Redis (optional, for persistent caching across instances)
# Format: redis://host:6379/0
REDIS_URL=

# Branding
APP_NAME=DeFi Tracker
